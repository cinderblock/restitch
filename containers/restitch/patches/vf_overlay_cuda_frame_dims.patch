--- a/libavfilter/vf_transpose_npp.c
+++ b/libavfilter/vf_transpose_npp.c
@@ -376,6 +376,11 @@ static int npptranspose_filter(AVFilterContext *ctx, AVFrame *out, AVFrame *in)
     if (ret < 0)
         return ret;
 
+    /* match nppscale_scale: the pool allocates FFALIGN(w,32) frames; without
